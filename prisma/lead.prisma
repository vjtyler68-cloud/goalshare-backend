// Server-side Leads (a sales rep's customer list). Previously phone-only
// (Hive box leads_v1); now persisted per user so leads survive app deletion
// and follow the user across devices. See docs/path-to-launch.md TASK 1.
model Lead {
    id String @id @default(auto()) @map("_id") @db.ObjectId

    // Temporary id generated by the phone before the server assigned a real
    // id. Kept for dedupe: the same (userId, clientId) is never created twice,
    // which makes POST retries and the one-time /leads/sync upload idempotent.
    clientId String @default("")

    name    String
    phone   String @default("")
    email   String @default("")
    address String @default("")
    company String @default("")

    // One of: New | Contacted | Appointment | Won | Lost. Stored as a plain
    // string (normalised in the service layer) so unknown values coming from
    // older app builds can be coerced to "New" instead of failing the write.
    status String @default("New")

    notes String @default("")

    // When the rep wants to be reminded to reach out. Null = no reminder.
    reminderAt DateTime?

    userId String @db.ObjectId
    user   User   @relation(fields: [userId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("lead")
}
