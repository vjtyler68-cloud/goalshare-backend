model User {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  fullName     String
  businessType String?
  email        String       @unique
  phoneNumber  String?      @unique
  password     String
  role         UserRoleEnum @default(USER)

  status UserStatus @default(ACTIVE)

  describe String?
  city     String?
  address  String?
  profile  String?

  isAgreeWithTerms Boolean

  otp       String?
  otpExpiry DateTime?
  fcmToken  String?

  isEmailVerified Boolean @default(false)
  isApproved      Boolean @default(false)
  isDeleted       Boolean @default(false)

  platform          String?
  planPurchaseToken String?
  subscriptionStart DateTime?
  subscriptionEnd   DateTime?
  hasUsedFree       Boolean       @default(false)
  subscriptionId    String? @db.ObjectId
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id])
  stripeCustomerId  String?

  payments      Payment[]
  motivation    Motivation[]
  notifications NotificationUser[]
  vision        Vision[]
  // communityMembers CommunityMembers[]

  followers Follow[] @relation("Followers")
  following Follow[] @relation("Following")
  // community Community[]
  goal      Goal[]
  budget    Budget[]

  // communityMessage           CommunityMessage[]
  // communityMessageReadStatus CommunityMessageReadStatus[]
  room                Room[]                @relation("RoomSender")
  Room                Room[]                @relation("RoomReceiver")
  groupMember         GroupMember[]
  groupChat           GroupChat[]
  groupChatReadStatus GroupChatReadStatus[]

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  chat              Chat[]              @relation("ChatReceiver")
  Chat              Chat[]              @relation("ChatSender")
  globalMyWhy       GlobalMyWhy[]
  globalAffirmation GlobalAffirmation[]

  @@map("users")
}

enum UserRoleEnum {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

model GlobalMyWhy {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  text String

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("my-why")
}

model GlobalAffirmation {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  text String

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("affirmation")
}
