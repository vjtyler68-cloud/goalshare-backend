model User {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  fullName    String
  email       String       @unique
  phoneNumber String?      @unique
  password    String
  role        UserRoleEnum @default(USER)

  status UserStatus @default(ACTIVE)

  describe String?
  city     String?
  address  String?
  profile  String?

  isAgreeWithTerms Boolean

  otp       String?
  otpExpiry DateTime?

  isEmailVerified Boolean @default(false)
  isApproved      Boolean @default(false)
  isDeleted       Boolean @default(false)

  subscriptionStart DateTime?
  subscriptionEnd   DateTime?
  hasUsedFree       Boolean       @default(false)
  subscriptionId    String?       @db.ObjectId
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id])
  stripeCustomerId  String?

  payments         Payment[]
  motivation       Motivation[]
  notifications    NotificationUser[]
  vision           Vision[]
  // communityMembers CommunityMembers[]

  followers Follow[]    @relation("Followers")
  following Follow[]    @relation("Following")
  // community Community[]
  goal      Goal[]
  budget    Budget[]

  // communityMessage           CommunityMessage[]
  // communityMessageReadStatus CommunityMessageReadStatus[]
  room                       Room[]                       @relation("RoomSender")
  Room                       Room[]                       @relation("RoomReceiver")
  groupMember                GroupMember[]
  groupChat                  GroupChat[]
  groupChatReadStatus        GroupChatReadStatus[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chat       Chat[]   @relation("ChatReceiver")
  Chat      Chat[]   @relation("ChatSender")

  @@map("users")
}

enum UserRoleEnum {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}
